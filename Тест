// ==UserScript==
// @name         Годжи — Настройки
// @namespace    http://tampermonkey.net/
// @version      4.1
// @match        https://godji.cloud/*
// @match        https://*.godji.cloud/*
// @updateURL    https://raw.githubusercontent.com/Randyluffu/Godji-ERP/main/godji_settings.user.js
// @downloadURL  https://raw.githubusercontent.com/Randyluffu/Godji-ERP/main/godji_settings.user.js
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    var _items = [];
    var _panel = null;
    var _inner = null;
    var _open = false;

    // ── Глобальный API регистрации (исправленный) ──────────────────────────
    window.__godjiRegisterSetting = function(config) {
        if (!config || !config.id) return;

        // Проверка на дубликаты
        var exists = _items.find(function(x) { return x.id === config.id; });
        if (exists) return;

        _items.push(config);

        // Если панель уже создана и открыта — перерисовываем список
        if (_inner) {
            renderSettingsList();
        }
    };

    // Обработка очереди, накопившейся до загрузки основного скрипта ERP
    if (window.__godjiSettingsQueue && Array.isArray(window.__godjiSettingsQueue)) {
        while (window.__godjiSettingsQueue.length > 0) {
            var cfg = window.__godjiSettingsQueue.shift();
            window.__godjiRegisterSetting(cfg);
        }
    }

    // Переопределяем массив очереди, чтобы новые добавления через push работали корректно,
    // если какой-то скрипт всё ещё использует старый метод
    window.__godjiSettingsQueue = {
        push: function(cfg) {
            window.__godjiRegisterSetting(cfg);
        }
    };

    function renderSettingsList() {
        if (!_inner) return;
        _inner.innerHTML = '';

        _items.forEach(function(item) {
            var row = document.createElement('div');
            row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:10px;border-bottom:1px solid rgba(255,255,255,0.05);';

            var info = document.createElement('div');
            info.style.cssText = 'display:flex;align-items:center;gap:12px;';

            var icon = document.createElement('div');
            icon.style.cssText = 'width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:' + (item.iconBg || '#444');
            icon.innerHTML = item.icon || '';

            var label = document.createElement('span');
            label.style.cssText = 'font-size:14px;font-weight:500;color:#eee;';
            label.textContent = item.label;

            info.appendChild(icon);
            info.appendChild(label);
            row.appendChild(info);

            if (item.type === 'toggle') {
                var btn = document.createElement('div');
                var active = typeof item.getState === 'function' ? item.getState() : false;

                btn.style.cssText = 'width:34px;height:18px;border-radius:10px;position:relative;cursor:pointer;transition:background 0.2s;';
                btn.style.background = active ? 'var(--mantine-color-gg_primary-filled, #cc0001)' : '#444';

                var circle = document.createElement('div');
                circle.style.cssText = 'width:12px;height:12px;background:#fff;border-radius:50%;position:absolute;top:3px;transition:left 0.2s;';
                circle.style.left = active ? '19px' : '3px';

                btn.appendChild(circle);
                btn.onclick = function() {
                    var newState = !(typeof item.getState === 'function' ? item.getState() : false);
                    if (typeof item.onToggle === 'function') item.onToggle(newState);
                    btn.style.background = newState ? 'var(--mantine-color-gg_primary-filled, #cc0001)' : '#444';
                    circle.style.left = newState ? '19px' : '3px';
                };
                row.appendChild(btn);
            } else {
                var actionBtn = document.createElement('button');
                actionBtn.textContent = 'Открыть';
                actionBtn.style.cssText = 'background:#333;border:none;color:#ccc;padding:5px 10px;border-radius:4px;font-size:12px;cursor:pointer;';
                actionBtn.onclick = function() {
                    if (typeof item.onClick === 'function') item.onClick();
                };
                row.appendChild(actionBtn);
            }

            _inner.appendChild(row);
        });
    }

    function createPanel() {
        if (_panel) return;

        _panel = document.createElement('div');
        _panel.style.cssText = 'position:fixed;right:-320px;top:0;width:300px;height:100vh;background:#1a1b1e;box-shadow:-2px 0 10px rgba(0,0,0,0.3);z-index:9999;transition:right 0.3s;display:flex;flex-direction:column;font-family:sans-serif;';

        var header = document.createElement('div');
        header.style.cssText = 'padding:16px;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;justify-content:space-between;align-items:center;';
        header.innerHTML = '<span style="color:#fff;font-weight:700;font-size:16px;">Настройки скриптов</span>';

        var close = document.createElement('div');
        close.textContent = '×';
        close.style.cssText = 'color:#888;cursor:pointer;font-size:24px;line-height:1;';
        close.onclick = hidePanel;
        header.appendChild(close);

        _inner = document.createElement('div');
        _inner.style.cssText = 'flex:1;overflow-y:auto;';

        _panel.appendChild(header);
        _panel.appendChild(_inner);
        document.body.appendChild(_panel);
    }

    function showPanel() {
        createPanel();
        renderSettingsList();
        setTimeout(function() { _panel.style.right = '0'; }, 10);
        _open = true;
    }

    function hidePanel() {
        if (_panel) _panel.style.right = '-320px';
        _open = false;
    }

    function createSidebarBtn() {
        if (document.getElementById('godji-settings-btn')) return;

        var navbar = document.querySelector('.Sidebar_linksInner__oW_p4');
        if (!navbar) return;

        var btn = document.createElement('a');
        btn.id = 'godji-settings-btn';
        btn.className = 'm_f07af9d2 mantine-NavLink-root';
        btn.style.cssText = 'cursor:pointer; margin-top: auto;';

        btn.innerHTML = `
            <div class="m_63f5926b mantine-NavLink-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div class="m_f07af9d2 mantine-NavLink-body">
                <span class="m_1f6ac4c4 mantine-NavLink-label">Настройки ERP</span>
            </div>
        `;

        btn.onclick = function(e) {
            e.preventDefault();
            if (_open) hidePanel(); else showPanel();
        };

        navbar.appendChild(btn);
    }

    // Регистрация собственных настроек
    window.__godjiRegisterSetting({
        id: 'godji-colors-toggle',
        label: 'Цвета меню',
        iconBg: '#cc0001',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>',
        type: 'toggle',
        getState: function() { return localStorage.getItem('godji_colors_enabled') === 'true'; },
        onToggle: function(v) {
            localStorage.setItem('godji_colors_enabled', v ? 'true' : 'false');
            document.dispatchEvent(new CustomEvent('godji_colors_toggle', { detail: { enabled: v } }));
        }
    });

    // Наблюдатель для вставки кнопки в сайдбар
    var _obs = new MutationObserver(function() {
        if (!document.getElementById('godji-settings-btn')) createSidebarBtn();
    });
    _obs.observe(document.body, { childList: true, subtree: true });

    setTimeout(createSidebarBtn, 1500);

})();
